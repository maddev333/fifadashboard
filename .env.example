# Copy this file to .env and fill in your values.

# For local dev, no base path needed (defaults to '/')
# For GitHub Pages, set this to '/your-repo-name/'
BASE_PATH=/

# Azure Maps subscription key. Restrict by HTTP referrer in the Azure Portal.
# On GitHub Actions, add this as an environment secret named VITE_AZURE_MAPS_KEY.
# Recommended referrer restriction: https://yourusername.github.io/*
# This key powers both the Live Map weather experience and the Intelligence Feed live weather signals.
VITE_AZURE_MAPS_KEY=your_azure_maps_key_here
